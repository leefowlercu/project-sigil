#!/usr/bin/env python3

from __future__ import annotations

import argparse
import re
import sys
from collections import Counter
from dataclasses import dataclass
from pathlib import Path


PRD_FILE_RE = re.compile(r"^(PRD-\d{4})-[a-z0-9-]+-specification\.md$")
PRD_SCENARIO_RE = re.compile(r"^### Scenario (SCN-(\d{4})): (.+)$")
FEATURE_SCENARIO_RE = re.compile(r"^\s*Scenario: (.+)$")
LEGACY_FEATURE_TAGS = {"@nonvisual", "@visual"}


@dataclass(frozen=True)
class Scenario:
    prd: str
    scenario_id: str
    title: str


@dataclass(frozen=True)
class MatrixScenario:
    scenario: Scenario
    feature_file: str


@dataclass(frozen=True)
class SubprojectConfig:
    prd_dir: str


SUBPROJECTS = {
    "sigil": SubprojectConfig(prd_dir="docs/sigil/PRD"),
    "sigil-web": SubprojectConfig(prd_dir="docs/sigil-web/PRD"),
}


def repo_root() -> Path:
    return Path(__file__).resolve().parents[1]


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(
        description="Verify PRD, MATRIX, and acceptance-title consistency.",
    )
    parser.add_argument(
        "--subproject",
        default="sigil",
        choices=tuple(sorted(SUBPROJECTS)),
        help="Subproject to verify.",
    )
    return parser.parse_args()


def parse_prds(prd_dir: Path) -> tuple[set[str], list[Scenario], list[str]]:
    errors: list[str] = []
    prd_ids: set[str] = set()
    scenarios: list[Scenario] = []

    for path in sorted(prd_dir.glob("PRD-*.md")):
        match = PRD_FILE_RE.match(path.name)
        if match is None:
            errors.append(f"invalid PRD filename: {path}")
            continue

        prd = match.group(1)
        prd_ids.add(prd)
        expected = 0
        for line_no, line in enumerate(path.read_text().splitlines(), start=1):
            scenario_match = PRD_SCENARIO_RE.match(line)
            if scenario_match is None:
                continue

            scenario_id = scenario_match.group(1)
            numeric = int(scenario_match.group(2))
            title = scenario_match.group(3).strip()
            if numeric != expected:
                errors.append(
                    f"{path}:{line_no} expected SCN-{expected:04d} but found {scenario_id}",
                )
                expected = numeric + 1
            else:
                expected += 1

            scenarios.append(Scenario(prd=prd, scenario_id=scenario_id, title=title))

    title_counts = Counter(item.title for item in scenarios)
    for title, count in sorted(title_counts.items()):
        if count > 1:
            errors.append(f"duplicate PRD scenario title ({count}): {title}")

    return prd_ids, scenarios, errors


def parse_matrix(matrix_path: Path) -> tuple[list[MatrixScenario], list[str]]:
    errors: list[str] = []
    scenarios: list[MatrixScenario] = []

    for line_no, line in enumerate(matrix_path.read_text().splitlines(), start=1):
        if not line.startswith("| `PRD-"):
            continue

        columns = [part.strip() for part in line.strip().strip("|").split("|")]
        if len(columns) != 6:
            errors.append(f"{matrix_path}:{line_no} expected 6 columns but found {len(columns)}")
            continue
        if any("TBD" in column.upper() for column in columns[:5]):
            errors.append(f"{matrix_path}:{line_no} contains unresolved placeholder content")
            continue

        prd, scenario_id, prd_title, mapped_feature, feature_title, _note = columns
        prd = prd.strip("`")
        scenario_id = scenario_id.strip("`")
        prd_title = prd_title.strip("`")
        mapped_feature = mapped_feature.strip("`")
        feature_title = feature_title.strip("`")

        if prd_title != feature_title:
            errors.append(
                f"{matrix_path}:{line_no} PRD title does not match mapped feature title: {prd_title!r} != {feature_title!r}",
            )

        scenarios.append(
            MatrixScenario(
                scenario=Scenario(prd=prd, scenario_id=scenario_id, title=prd_title),
                feature_file=mapped_feature,
            ),
        )

    return scenarios, errors


def parse_feature(feature_path: Path) -> tuple[set[str], list[str]]:
    errors: list[str] = []
    titles: list[str] = []
    pending_tags: set[str] = set()

    for line_no, line in enumerate(feature_path.read_text().splitlines(), start=1):
        stripped = line.strip()
        if not stripped:
            continue

        if stripped.startswith("@"):
            tokens = stripped.split()
            invalid_tokens = [token for token in tokens if not token.startswith("@")]
            if invalid_tokens:
                errors.append(f"{feature_path}:{line_no} invalid feature tags line: {stripped!r}")
            for token in tokens:
                if token in LEGACY_FEATURE_TAGS:
                    errors.append(
                        f"{feature_path}:{line_no} remove legacy feature tag {token}; sigil-web now uses behavior-first acceptance titles without visual-only feature tags",
                    )
            pending_tags.update(tokens)
            continue

        scenario_match = FEATURE_SCENARIO_RE.match(line)
        if scenario_match is not None:
            titles.append(scenario_match.group(1).strip())
            pending_tags.clear()
            continue

        pending_tags.clear()

    counts = Counter(titles)
    for title, count in sorted(counts.items()):
        if count > 1:
            errors.append(f"duplicate feature scenario title ({count}): {title}")

    return set(titles), errors


def main() -> int:
    args = parse_args()
    root = repo_root()
    config = SUBPROJECTS[args.subproject]
    prd_dir = root / config.prd_dir
    matrix_path = prd_dir / "MATRIX.md"
    prd_ids, prd_scenarios, prd_errors = parse_prds(prd_dir)
    matrix_scenarios, matrix_errors = parse_matrix(matrix_path)

    feature_titles_by_file: dict[str, set[str]] = {}
    feature_errors: list[str] = []
    for feature_file in sorted({scenario.feature_file for scenario in matrix_scenarios}):
        feature_path = root / feature_file
        if not feature_path.exists():
            feature_errors.append(f"missing feature file: {feature_file}")
            continue
        feature_titles, file_errors = parse_feature(feature_path)
        feature_titles_by_file[feature_file] = feature_titles
        feature_errors.extend(file_errors)

    errors = [*prd_errors, *matrix_errors, *feature_errors]

    prd_set = set(prd_scenarios)
    matrix_set = {item.scenario for item in matrix_scenarios}

    missing_from_matrix = sorted(prd_set - matrix_set, key=lambda item: (item.prd, item.scenario_id))
    missing_from_prd = sorted(matrix_set - prd_set, key=lambda item: (item.prd, item.scenario_id))

    for scenario in missing_from_matrix:
        errors.append(f"missing from MATRIX: {scenario.prd} {scenario.scenario_id} {scenario.title}")
    for scenario in missing_from_prd:
        errors.append(f"missing from PRDs: {scenario.prd} {scenario.scenario_id} {scenario.title}")

    for matrix_scenario in matrix_scenarios:
        feature_titles = feature_titles_by_file.get(matrix_scenario.feature_file, set())
        if matrix_scenario.scenario.title not in feature_titles:
            errors.append(
                "missing from feature:"
                + f" {matrix_scenario.scenario.prd}"
                + f" {matrix_scenario.scenario.scenario_id}"
                + f" {matrix_scenario.scenario.title}"
                + f" ({matrix_scenario.feature_file})",
            )

    if errors:
        for error in errors:
            print(f"ERROR: {error}", file=sys.stderr)
        return 1

    print(
        f"verified {args.subproject} specs:",
        f"prds={len(prd_ids)}",
        f"scenarios={len(prd_scenarios)}",
        f"feature_titles={sum(len(items) for items in feature_titles_by_file.values())}",
    )
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
